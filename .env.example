# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Frontend (Vite): must be prefixed VITE_, accessed via import.meta.env.VITE_*
# VITE_APP_NAME=poe2-waystone-overlay

# Rust backend (src-tauri) debug flags — optional, dev-only, no secrets.
# Set as real OS env vars before `npm run tauri:dev`, not read from .env.
# OVERLAY_DEBUG_OPAQUE=1
# OVERLAY_CLICK_THROUGH=0
