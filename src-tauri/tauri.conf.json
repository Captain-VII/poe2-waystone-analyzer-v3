{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waystone-overlay",
  "version": "0.2.0-beta.1",
  "identifier": "me.dorian.waystone-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Dorian Dubosc",
    "shortDescription": "PoE2 Waystone analysis overlay",
    "longDescription": "An in-game overlay that reads a copied Path of Exile 2 Waystone and shows its heat score, tier verdict, and recommended tablets in a dark-fantasy relic-styled Compact/Full panel.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
