{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waystone-Analyzer",
  "mainBinaryName": "Waystone-Analyzer",
  "version": "0.2.8",
  "identifier": "me.dorian.waystone-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1NjQ3MjBDRDdEN0FDMDIKUldRQ3JOZlhESEprWlhLVmxlWjlxTjIyaFJ3OXJ1bXZvR3dTMFJaSVN4TklBSnJRMHVTTTlzTzcK",
      "endpoints": [
        "https://github.com/Captain-VII/poe2-waystone-analyzer-v3/releases/download/updater/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Dorian Dubosc",
    "shortDescription": "PoE2 Waystone analysis overlay",
    "longDescription": "An in-game overlay that reads a copied Path of Exile 2 Waystone and shows its heat score, tier verdict, and recommended tablets in a dark-fantasy relic-styled Compact/Full panel.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
